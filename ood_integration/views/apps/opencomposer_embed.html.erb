<div id="oc-container" style="position:fixed; left:0; right:0; overflow:hidden;">
  <iframe id="oc-frame" src="/pun/sys/opencomposer/" style="width:100%; height:100%; border:none;"></iframe>
</div>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    var container = document.getElementById('oc-container');
    var navbar = document.querySelector('nav.navbar');
    var footer = document.querySelector('footer');
    container.style.top    = (navbar ? navbar.offsetHeight : 56) + 'px';
    container.style.bottom = (footer ? footer.offsetHeight : 0)  + 'px';
  });
</script>
