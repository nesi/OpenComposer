<%# ── Load Script from Disk: file-browser modal (shared partial) ──────────── %>
<%# Rendered with `erb :load_script_modal, layout: false` from index.erb and    %>
<%# new_template.erb. Pages add their own trigger button:                       %>
<%#   <button data-bs-toggle="modal" data-bs-target="#oc-ls-modal">…</button>   %>
<%# Pass `locals: { new_template: true }` to open the target form in            %>
<%# new-template mode (no Submit button, "Save as Custom Template" primary).    %>
<% new_template = false unless defined?(new_template) %>
<div class="modal fade" id="oc-ls-modal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h5 class="modal-title fs-6">Load Script from Disk</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="d-flex align-items-center gap-2 mb-2">
          <button type="button" id="oc-ls-up" class="btn btn-sm btn-outline-secondary text-nowrap" title="Go to parent directory">
            <i class="bi bi-arrow-90deg-up"></i> Up
          </button>
          <code id="oc-ls-path" class="small text-truncate flex-grow-1"></code>
          <div class="form-check m-0 text-nowrap">
            <input type="checkbox" class="form-check-input" id="oc-ls-hidden">
            <label class="form-check-label small" for="oc-ls-hidden">Show hidden</label>
          </div>
        </div>
        <div class="small text-muted mb-2">
          Select a <code>.sl</code>, <code>.sh</code> or <code>.sbatch</code> file to load into the Slurm script editor.
        </div>
        <div id="oc-ls-list" class="list-group border rounded" style="min-height: 240px; max-height: 50vh; overflow-y: auto;"></div>
        <div id="oc-ls-error" class="text-danger small mt-2" style="display: none;"></div>
      </div>
      <div class="modal-footer py-2">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
        <button type="button" class="btn btn-primary btn-sm" id="oc-ls-load" disabled>Load Script</button>
      </div>
    </div>
  </div>
</div>

<script>
// ── Load Script from Disk ──────────────────────────────────────────────────
// Browses the filesystem via the existing /_files endpoint, reads the chosen
// .sl/.sh/.sbatch file via /_read_file, then reuses the History page's
// "load into generic app" flow: POST history/save_external_script for the
// target URL, stash the payload in sessionStorage, navigate with ?ocExtLoad=.
(function() {
  var modalEl = document.getElementById('oc-ls-modal');
  if (!modalEl) return;
  var base     = '<%= @script_name %>';
  var listEl   = document.getElementById('oc-ls-list');
  var pathEl   = document.getElementById('oc-ls-path');
  var upBtn    = document.getElementById('oc-ls-up');
  var loadBtn  = document.getElementById('oc-ls-load');
  var hiddenCb = document.getElementById('oc-ls-hidden');
  var errEl    = document.getElementById('oc-ls-error');
  var HOME     = '<%= Dir.home %>';
  var NEW_TEMPLATE = <%= new_template ? 'true' : 'false' %>;
  var SCRIPT_RE = /\.(sl|sh|sbatch)$/i;
  var current  = HOME;
  var entries  = [];
  var selected = null;

  function setError(msg) {
    errEl.textContent = msg || '';
    errEl.style.display = msg ? '' : 'none';
  }

  function render() {
    listEl.innerHTML = '';
    selected = null;
    loadBtn.disabled = true;
    var showHidden = hiddenCb.checked;
    var shown = 0;
    entries.forEach(function(e) {
      if (!showHidden && e.name.charAt(0) === '.') return;
      var isDir = e.type === 'directory';
      if (!isDir && !SCRIPT_RE.test(e.name)) return;
      shown++;
      var item = document.createElement('button');
      item.type = 'button';
      item.className = 'list-group-item list-group-item-action py-1 d-flex align-items-center gap-2';
      var icon = document.createElement('i');
      icon.className = isDir ? 'bi bi-folder-fill text-warning' : 'bi bi-file-earmark-code';
      var name = document.createElement('span');
      name.textContent = e.name + (isDir ? '/' : '');
      item.appendChild(icon);
      item.appendChild(name);
      if (isDir) {
        item.addEventListener('click', function() { browse(e.path); });
      } else {
        item.addEventListener('click', function() {
          listEl.querySelectorAll('.active').forEach(function(a) { a.classList.remove('active'); });
          item.classList.add('active');
          selected = e.path;
          loadBtn.disabled = false;
        });
        item.addEventListener('dblclick', function() { loadScript(e.path); });
      }
      listEl.appendChild(item);
    });
    if (shown === 0) {
      var empty = document.createElement('div');
      empty.className = 'list-group-item small text-muted';
      empty.textContent = 'No directories or .sl/.sh/.sbatch files here.';
      listEl.appendChild(empty);
    }
  }

  function browse(path) {
    setError('');
    fetch(base + '/_files?path=' + encodeURIComponent(path))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!Array.isArray(data.files)) { setError('Cannot open ' + path); return; }
        current = path;
        pathEl.textContent = path;
        entries = data.files;
        render();
      })
      .catch(function(e) { setError('Error: ' + e.message); });
  }

  var loading = false;  // re-entry guard: dblclick or double-Enter must not start two loads

  function loadScript(path) {
    if (loading) return;
    loading = true;
    setError('');
    loadBtn.disabled = true;
    loadBtn.textContent = 'Loading…';
    fetch(base + '/_read_file?path=' + encodeURIComponent(path))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.error) { throw new Error(data.error); }
        var script = data.empty ? '' : (data.content || '');
        if (data.truncated) {
          setError('Warning: file is larger than 1 MB and was truncated.');
        }
        return fetch(base + '/history/save_external_script', { method: 'POST' })
          .then(function(r) { return r.json(); })
          .then(function(target) {
            if (!target.url) { throw new Error(target.error || 'No target app URL'); }
            var payload = {
              script:         script,
              scriptLocation: path.replace(/\/[^/]*$/, '') || '/',
              scriptName:     path.split('/').pop(),
              jobName:        ''
            };
            var key = '_oc_ext_' + Date.now();
            sessionStorage.setItem(key, JSON.stringify(payload));
            var sep = target.url.indexOf('?') >= 0 ? '&' : '?';
            var extra = NEW_TEMPLATE ? '&new_template=1' : '';
            window.location.href = target.url + sep + 'ocExtLoad=' + encodeURIComponent(key) + extra;
          });
      })
      .catch(function(e) {
        loading = false;
        setError('Error: ' + e.message);
        loadBtn.disabled = false;
        loadBtn.textContent = 'Load Script';
      });
  }

  upBtn.addEventListener('click', function() {
    if (current === '/') return;
    browse(current.replace(/\/[^/]*$/, '') || '/');
  });
  hiddenCb.addEventListener('change', render);
  loadBtn.addEventListener('click', function() { if (selected) loadScript(selected); });
  modalEl.addEventListener('shown.bs.modal', function() {
    loading = false;
    loadBtn.textContent = 'Load Script';
    browse(current);
  });
})();
</script>
