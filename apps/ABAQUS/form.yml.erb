<%
form = {
  'abaqus_module' => {
    'widget' => 'module_load',
    'module' => 'ABAQUS',
    'label'  => 'ABAQUS Module'
  },

  'partition' => {
    'widget'  => 'select',
    'label'   => 'Partition',
    'options' => [
      [ 'any',   '',      'set-max-cores_simple: 166', 'set-max-memory_total_gb: 1450', 'set-max-memory_per_cpu_gb: 8' ],
      [ 'genoa', 'genoa', 'set-max-cores_simple: 166', 'set-max-memory_total_gb: 1450', 'set-max-memory_per_cpu_gb: 8' ],
      [ 'milan', 'milan', 'set-max-cores_simple: 126', 'set-max-memory_total_gb: 1000', 'set-max-memory_per_cpu_gb: 8' ]
    ]
  },

  'mp_mode_type' => {
    'widget'    => 'radio',
    'label'     => 'Memory Type',
    'value'     => 'Shared Memory',
    'direction' => 'horizontal',
    'options'   => [
      [ 'Shared Memory',     'threads', 'enable-cpus_per_task', 'enable-memory_total_gb', 'disable-ntasks', 'disable-memory_per_cpu_gb' ],
      [ 'Distributed Memory','mpi',     'disable-cpus_per_task','disable-memory_total_gb','enable-ntasks',  'enable-memory_per_cpu_gb'  ]
    ]
  },

  'cpus_per_task' => {
    'widget' => 'number',
    'label'  => 'CPUs per Task',
    'value'  => 4,
    'min'    => 1,
    'step'   => 1
  },

  'memory_total_gb' => {
    'widget' => 'number',
    'label'  => 'Total Memory (GB)',
    'value'  => 8,
    'min'    => 1,
    'step'   => 1
  },

  'ntasks' => {
    'widget' => 'number',
    'label'  => 'Number of Tasks (MPI)',
    'value'  => 4,
    'min'    => 1,
    'step'   => 1
  },

  'memory_per_cpu_gb' => {
    'widget' => 'number',
    'label'  => 'Memory per CPU (GB)',
    'value'  => 2,
    'min'    => 1,
    'max'    => 8,
    'step'   => 1
  },

  'number_of_nodes' => {
    'widget' => 'number',
    'label'  => 'Number of Nodes',
    'min'    => 1,
    'step'   => 1,
    'help'   => "Leave empty if you don't want to specify the number of nodes."
  },

  'time_days_hours_minutes' => {
    'widget' => 'number',
    'label'  => [ 'Time (Days)', '(Hours)', '(Minutes)', '(Seconds)' ],
    'size'   => 4,
    'value'  => [ 0, 0, 15, 0 ],
    'min'    => [ 0, 0, 0, 0 ],
    'max'    => [ 21, 23, 59, 59 ],
    'step'   => [ 1, 1, 1, 1 ]
  },

  'show_advanced_option' => {
    'widget'  => 'checkbox',
    'label'   => nil,
    'options' => [
      [ 'Show advanced option', '', 'show-testing', 'show-profiling', 'show-array', 'show-mail_option',
        'enable-testing', 'enable-profiling', 'enable-array', 'enable-mail_option' ]
    ]
  },

  'testing' => {
    'widget'    => 'checkbox',
    'label'     => 'Testing',
    'direction' => 'horizontal',
    'separator' => ',',
    'indent'    => 1,
    'options'   => [
      [ 'Perform a high priority test (15 mins)', 'debug',
        'set-time_days_hours_minutes_1: 0', 'set-time_days_hours_minutes_2: 0',
        'set-time_days_hours_minutes_3: 15', 'set-time_days_hours_minutes_4: 0' ]
    ]
  },

  'profiling' => {
    'widget'    => 'checkbox',
    'label'     => 'Profiling',
    'direction' => 'horizontal',
    'separator' => ',',
    'indent'    => 1,
    'options'   => [
      [ 'Profile my Job', 'task', 'show-profiling_time', 'enable-profiling_time' ]
    ]
  },

  'profiling_time' => {
    'widget' => 'number',
    'label'  => 'Record information about the job every X seconds',
    'indent' => 1,
    'value'  => 30,
    'min'    => 1,
    'max'    => 60,
    'step'   => 1
  },

  'array' => {
    'widget' => 'number',
    'label'  => [ 'Array Job (start index)', 'Array Job (last index)', 'Array Job (jump)' ],
    'size'   => 3,
    'indent' => 1,
    'value'  => [ nil, nil, 1 ],
    'min'    => [ 0, 0, 1 ],
    'help'   => 'Each job executed from an array job is assigned a task ID, which can be referenced in the shell script via the environment variable SLURM_ARRAY_TASK_ID.'
  },

  'mail_option' => {
    'widget'    => 'checkbox',
    'label'     => 'Mail option',
    'direction' => 'horizontal',
    'separator' => ',',
    'indent'    => 1,
    'options'   => [
      [ 'Beginning of job execution', 'BEGIN'   ],
      [ 'End of job execution',       'END'     ],
      [ 'Fail of job',                'FAIL'    ],
      [ 'When the job is requeued',   'REQUEUE' ],
      [ 'All',                        'ALL'     ]
    ]
  }
}

script = <<~'SCRIPT'
  #!/bin/bash -e
  #SBATCH --job-name=#{OC_JOB_NAME}
  #SBATCH --partition=#{partition}
  #SBATCH --cpus-per-task=#{cpus_per_task}
  #SBATCH --ntasks=#{ntasks}
  #SBATCH --nodes=#{number_of_nodes}
  #SBATCH --mem=#{memory_total_gb}G
  #SBATCH --mem-per-cpu=#{memory_per_cpu_gb}G
  #SBATCH --time=#{time_days_hours_minutes_1}-#{zeropadding(time_days_hours_minutes_2,2)}:#{zeropadding(time_days_hours_minutes_3,2)}:#{zeropadding(time_days_hours_minutes_4,2)}
  #SBATCH --array=#{array_1}-#{array_2}:#{array_3}
  #SBATCH --qos=#{testing}
  #SBATCH --profile=#{profiling}
  #SBATCH --acctg-freq=#{profiling_time}
  #SBATCH --mail-type=#{mail_option}

  module -q purge
  module load #{abaqus_module}

  abaqus job="example" mp_mode=#{mp_mode_type} cpus=${SLURM_CPUS_PER_TASK:-${SLURM_NTASKS}} verbose=2 interactive
SCRIPT
%>
<%= ({ 'form' => form, 'script' => script }).to_yaml -%>
