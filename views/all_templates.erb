<div style="display:flex; flex-direction:column; height:calc(100vh - 56px);">
  <div id="oc-all-list" style="flex:1; overflow-y:auto; min-height:0; background:#F3F4F4; border-top:1px solid #C3C8C8;">
    <% @all_manifests.each do |m| %>
      <a href="<%= @script_name %>/<%= ERB::Util.h(m.dirname) %>" class="d-block text-decoration-none py-2 px-3 border-bottom oc-all-item"
         data-name="<%= ERB::Util.h(m.name.to_s.downcase) %>"
         data-desc="<%= ERB::Util.h(m.description.to_s.downcase) %>"
         data-cat="<%= ERB::Util.h(m.category.to_s.downcase) %>">
        <div>
          <% if m.category %>
            <span class="badge text-bg-secondary me-1"><%= ERB::Util.h(m.category) %></span>
          <% end %>
          <% if @gpu_names.include?(m.name.to_s.downcase) || m.tags.map(&:downcase).include?("gpu") %>
            <span class="badge text-bg-success me-1">GPU</span>
          <% end %>
          <span class="fw-semibold"><%= ERB::Util.h(m.name) %></span>
        </div>
        <% if m.description && m.description.strip != '' %>
          <div class="small text-muted"><%= ERB::Util.h(m.description) %></div>
        <% end %>
      </a>
    <% end %>
  </div>
  <div id="oc-all-no-results" class="px-4 py-2 small text-muted d-none flex-shrink-0">No templates match your search.</div>
</div>

<script>
(function() {
  function filterList(q) {
    var items = document.querySelectorAll('#oc-all-list .oc-all-item');
    var visible = 0;
    items.forEach(function(item) {
      var match = !q || item.dataset.name.includes(q) || item.dataset.desc.includes(q) || item.dataset.cat.includes(q);
      item.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    document.getElementById('oc-all-no-results').classList.toggle('d-none', visible > 0);
  }

  // Register with the layout's search handler (runs before layout's script block).
  window._ocAllTemplatesSearch = function(q) { filterList(q); };

  // Focus the search bar after everything has loaded.
  window.addEventListener('load', function() {
    var input = document.getElementById('oc-search');
    if (input) input.focus();
  });
})();
</script>
