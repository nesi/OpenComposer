<%
base_path = File.join(File.dirname(yml_path), '../SlurmGPU/form.yml')
base = read_yaml(base_path)

# Only disable cuda_module when switching back to the non-GPU "any" partition.
base['form']['partition']['options'] = base['form']['partition']['options'].map do |opt|
  label, value, *rest = opt
  if value.to_s.empty?
    [label, value, *rest, 'disable-cuda_module']
  else
    [label, value, *rest]
  end
end

# Only hook cuda_module / matlab_gpu_batch visibility onto gpu_any (the primary GPU selector).
# gpu_genoa and gpu_milan are set programmatically; their hidden "None" state
# must not override the enable triggered by gpu_any.
if base['form']['gpu_any']
  base['form']['gpu_any']['options'] = base['form']['gpu_any']['options'].map do |opt|
    label, value, *rest = opt
    if value.to_s.empty?
      [label, value, *rest, 'disable-cuda_module', 'disable-matlab_gpu_batch']
    else
      [label, value, *rest, 'enable-cuda_module', 'enable-matlab_gpu_batch']
    end
  end
end

new_form = {}
base['form'].each do |k, v|
  if k == 'time_days_hours_minutes'
    new_form['matlab_module'] = {
      'widget' => 'module_load',
      'module' => "MATLAB",
      'label'  => "MATLAB Module"
    }
    new_form['cuda_module'] = {
      'widget' => 'module_load',
      'module' => "CUDA",
      'label'  => "CUDA Module"
    }
    new_form['matlab_gpu_batch'] = {
      'widget' => 'text',
      'label'  => 'GPU Batch Flag',
      'value'  => '-batch "gpuDevice()" '
    }
  end
  new_form[k] = v
end

base['form']   = new_form
base['script'] = base['script'].rstrip + "\n\n" + <<~'APP_SCRIPT'
  module -q purge
  module load #{matlab_module}
  module load #{cuda_module}

  # Run the MATLAB script MATLAB_job.m
  matlab #{:matlab_gpu_batch}-nodisplay < MATLAB_job.m
APP_SCRIPT
%>
<%= base.to_yaml -%>
