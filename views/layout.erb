<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <link href="<%= @script_name %>/fontawesome-6.7.2/css/all.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/<%= @conf['highlight_theme'] %>.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/highlight.min.js"></script>
    <title>
      <%= "#{@name} | Open Composer" %>
    </title>
    <style>
      #<%= OC_SCRIPT_CONTENT %>, #<%= SUBMIT_CONTENT %>, #<%= OC_SCRIPT_CONTENT %>_highlight, #<%= SUBMIT_CONTENT %>_highlight {
        font-family: 'JetBrains Mono', monospace;
      }
      #<%= OC_SCRIPT_CONTENT %>_editor, #<%= SUBMIT_CONTENT %>_editor {
        display: flex;
        min-height: 0;
      }
      #<%= OC_SCRIPT_CONTENT %>_highlight_container, #<%= SUBMIT_CONTENT %>_highlight_container {
        position: absolute;
        inset: 0;
        margin: 0;
        padding: 0;
        overflow: hidden;
        pointer-events: none;
        line-height: 1.5;
        white-space: pre-wrap;
        word-break: break-word;
        background: transparent;
        border-radius: 0.375rem;
        scrollbar-width: none;
        -ms-overflow-style: none;
      }
      #<%= OC_SCRIPT_CONTENT %>_highlight.hljs, #<%= SUBMIT_CONTENT %>_highlight.hljs {
        display: block;
        width: 100%;
        min-height: 100%;
        box-sizing: border-box;
        padding: 0.25rem 0.75rem 0;
        font-size: inherit;
        line-height: inherit;
        white-space: inherit;
        word-break: inherit;
      }
      #<%= OC_SCRIPT_CONTENT %>_highlight_container::-webkit-scrollbar,
      #<%= SUBMIT_CONTENT %>_highlight_container::-webkit-scrollbar,
      #<%= OC_SCRIPT_CONTENT %>_highlight::-webkit-scrollbar,
      #<%= SUBMIT_CONTENT %>_highlight::-webkit-scrollbar {
        display: none;
      }
      .oc-scheduler-directive {
        color: <%= @conf['directive_color'] %> !important;
        font-style: normal !important;
      }
      .oc-scheduler-directive * {
        color: <%= @conf['directive_color'] %> !important;
        font-style: normal !important;
      }
      #<%= OC_SCRIPT_CONTENT %>, #<%= SUBMIT_CONTENT %> {
        z-index: 1;
        width: 100%;
        height: 100%;
        resize: none;
        line-height: 1.5;
        color: transparent;
        background: transparent;
        border-color: transparent;
        scrollbar-width: none;
        -ms-overflow-style: none;
      }
      #<%= OC_SCRIPT_CONTENT %>::-webkit-scrollbar, #<%= SUBMIT_CONTENT %>::-webkit-scrollbar {
        display: none;
      }
      .oc-script-placeholder-hint {
        color: rgba(108, 117, 125, 0.55);
        font-style: italic;
        white-space: pre;
        pointer-events: none;
      }
      #<%= OC_SCRIPT_CONTENT %>:focus, #<%= SUBMIT_CONTENT %>:focus {
        background: transparent;
        border-color: transparent;
        box-shadow: none;
      }
      #<%= OC_SCRIPT_CONTENT %>_editor:focus-within #<%= OC_SCRIPT_CONTENT %>_highlight_container,
      #<%= SUBMIT_CONTENT %>_editor:focus-within #<%= SUBMIT_CONTENT %>_highlight_container {
        border-color: #86b7fe;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
      }
      body {
        min-width: 768px;
      }
      #_form_container {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }
      .ood-logo {
        filter: invert(1) grayscale(100%);
      }
      a:hover .ood-logo {
        filter: brightness(0) invert(1) grayscale(100%);
      }

      /* The timing of Bootstrap's navigation animation (which changes color when the mouse cursor is over it) differs
         from the animation for the Open OnDemand image that you added, so turn off Bootstrap animations. */
     .nav-link {
       transition: none !important;
     }
     .nav-link:hover {
       color: <%= @conf['navbar_text_color'] %> !important;
     }
      <% if @dir_name == "history" %>
      #_historyTbody td {
        vertical-align: middle;
      }

      .history-sort-controls {
        display: inline-flex;
        flex-direction: column;
        gap: 0;
        margin-left: 0.15rem;
        vertical-align: middle;
      }

      .history-sort-link {
        color: rgba(70, 48, 32, 0.82);
        display: block;
        font-size: 0.62rem;
        font-weight: 700;
        height: 0.56rem;
        line-height: 0.56rem;
        min-width: 0.7rem;
        padding: 0;
        text-align: center;
        text-decoration: none;
      }

      .history-sort-icon {
        display: inline-block;
        transform: scaleX(1.55);
        transform-origin: center;
      }

      .history-sort-link:hover {
        color: #b85400;
      }

      .history-sort-link.history-sort-active {
        color: #d11f1f;
      }

      .history-modal-match-cell {
        box-shadow: inset 0 0 0 2px transparent;
      }

      .history-modal-match-cell.history-modal-match-active {
        box-shadow: inset 0 0 0 2px var(--bs-warning);
      }

      .badge-completed {
        background-color: #5cb85c !important;
        color: #fff !important;
      }
      .badge-cancelled {
        background-color: #fd7e14 !important;
        color: #000 !important;
      }
      <% end %>
     </style>
  </head>

  <body style="visibility: hidden;">
    <div id="_form_container" class="container-fluid">
      <nav class="navbar navbar-expand mx-1 bg-gradient" style="background:<%= @conf['navbar_color'] %>; --bs-navbar-color: <%= @conf['navbar_text_color'] %>; --bs-navbar-hover-color: <%= @conf['navbar_text_color'] %>; --bs-navbar-active-color: <%= @conf['navbar_text_color'] %>; --bs-navbar-brand-color: <%= @conf['navbar_text_color'] %>; --bs-navbar-brand-hover-color: <%= @conf['navbar_text_color'] %>;">
        <div class="container-fluid">
          <div class="collapse navbar-collapse">
            <ul class="navbar-nav">
              <% if @conf["navbar_logo"].to_s.strip.length > 0 %>
                <li class="nav-item d-flex align-items-center px-2">
                  <img src="<%= @script_name %>/<%= @conf["navbar_logo"] %>" alt="Logo" style="height: 30px; vertical-align: middle;">
                </li>
              <% end %>
              <li class="nav-item">
                <a href="<%= @script_name %>/" class="nav-link <%= active?("" == @dir_name) %>">Home</a>
              </li>
              <li class="nav-item dropdown">
                <a href="#" class="nav-link dropdown-toggle <%= active?("" != @dir_name && "history" != @dir_name && "nodes" != @dir_name) %>" data-bs-toggle="dropdown">
                  Application
                </a>
                <ul class="dropdown-menu dropdown-menu-dark bg-gradient" style="background:<%= @conf['dropdown_color'] %>; max-height: 80vh; overflow-y: auto;">
                  <% @manifests_w_category.group_by(&:category).each do |category, manifests| %>
                    <li class="dropdown-header"><%= category %></li>
                    <% manifests.each do |m| %>
                      <li>
                        <a href="<%= @script_name %>/<%= m['dirname'] %>" class="dropdown-item <%= active?(m['dirname'] == @dir_name) %>">
                          <%= m['name'] %>
                        </a>
                      </li>
                    <% end %>
                    <li><hr class="dropdown-divider"></li>
                  <% end %>
                  <% @manifests_wo_category.each do |m| %>
                    <li>
                      <a href="<%= @script_name %>/<%= m['dirname'] %>" class="dropdown-item <%= active?(m['dirname'] == @dir_name) %>">
                        <%= m['name'] %>
                      </a>
                    </li>
                  <% end %>
                </ul>
              </li>
              <li class="nav-item">
                <a href="<%= @script_name %>/history" class="nav-link <%= active?("history" == @dir_name) %>">History</a>
              </li>
              <li class="nav-item">
                <a href="<%= @script_name %>/nodes" class="nav-link <%= active?("nodes" == @dir_name) %>">Nodes</a>
              </li>
            </ul>

            <ul class="navbar-nav ms-auto">
              <li class="nav-item me-2">
                <input type="search" id="oc-search" class="form-control form-control-sm"
                       placeholder="Search apps…" autocomplete="off" style="width:180px;">
              </li>
              <% if @conf["show_home_directory"] %>
                <li class="nav-item">
                  <a target="_blank" href="<%= @my_ood_url %>/pun/sys/dashboard/files" class="nav-link py-0">
                    <i class="fas fa-home fa-fw" style="font-size: 20px; display: inline-block; vertical-align: middle;" aria-hidden="true"></i>
                    <span class="d-none d-lg-inline ms-1" style="display: inline-block; vertical-align: middle;">Home Directory</span>
                  </a>
                </li>
              <% end %>
              <% if @conf["show_shell_access"] && !@login_node.nil? %>
                <% if @conf["login_node"].is_a?(Hash) && @conf["login_node"].values.compact.uniq.size > 1 %>
                  <li class="nav-item dropdown">
                    <a href="#" class="nav-link dropdown-toggle py-0" data-bs-toggle="dropdown">
                      <i class="bi bi-terminal-fill" style="font-size: 20px; vertical-align: middle;"></i>
                      <span class="d-none d-lg-inline ms-1" style="display: inline-block; vertical-align: middle;">Shell Access</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-dark bg-gradient" style="background:<%= @conf['dropdown_color'] %>; --bs-dropdown-min-width: 100%;">
                      <% @conf["login_node"].each do |key, value| %>
                        <li><a target="_blank" href="<%= @my_ood_url %>/pun/sys/shell/ssh/<%= value %>" class="dropdown-item"><%= key %></a></li>
                      <% end %>
                    </ul>
                  </li>
                <% else %>
                  <li class="nav-item">
                    <a target="_blank" href="<%= @my_ood_url %>/pun/sys/shell/ssh/<%= @login_node %>" class="nav-link py-0">
                      <i class="bi bi-terminal-fill" style="font-size: 20px; display: inline-block; vertical-align: middle;" aria-hidden="true"></i>
                      <span class="d-none d-lg-inline ms-1" style="display: inline-block; vertical-align: middle;">Shell Access</span>
                    </a>
                  </li>
                <% end %>
              <% end %>
              <% if @conf["show_open_ondemand"] %>
                <li class="nav-item">
                  <a target="_blank" href="<%= @my_ood_url %>" class="nav-link py-0">
                    <img src="<%= @script_name %>/ood.png" alt="" style="height: 20px; display: inline-block; vertical-align: middle; filter: brightness(0);" aria-hidden="true">
                    <span class="ms-1" style="display: inline-block; vertical-align: middle;"><%= ERB::Util.h(@conf["open_ondemand_label"]) %></span>
                  </a>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      </nav>

      <div id="oc-search-results" style="display:none; background:#fff; border-bottom:1px solid #dee2e6; max-height:60vh; overflow-y:auto;"></div>

      <div style="flex: 1;">
        <%= yield %>
      </div>

      <footer class="footer py-1 bg-gradient mx-1 <%= @dir_name == '' ? 'mt-3' : '' %>" style="background:<%= @conf['footer_color'] %>;">
        <div class="row align-items-center" style="color:<%= @conf['footer_text_color'] %>; --bs-link-color: <%= @conf['footer_text_color'] %>; --bs-link-hover-color: <%= @conf['footer_text_color'] %>; --bs-link-opacity: 1;">
          <div class="col text-start"></div> <!-- An empty column to center the middle text -->
          <div class="col text-center"><%= @conf['footer'] %></div>
          <div class="col text-end small mx-3">Open Composer version: <%= @version %></div>
        </div>
      </footer>
    </div>

    <script>
    (function() {
      var ALL_APPS = <%= @all_manifests.map { |m| { dirname: m.dirname, name: m.name, category: m.category, description: m.description, gpu: @gpu_names.include?(m.name.to_s.downcase) } }.to_json.gsub('</', '<\/') %>;
      var scriptName = '<%= @script_name %>';

      function esc(s) {
        return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      }

      var input   = document.getElementById('oc-search');
      var results = document.getElementById('oc-search-results');

      input.addEventListener('input', function() {
        var q = this.value.trim().toLowerCase();
        var list = document.getElementById('oc-app-list');
        if (!q) {
          results.style.display = 'none';
          results.innerHTML = '';
          if (list) list.style.display = '';
          return;
        }
        if (list) list.style.display = 'none';
        results.style.display = '';

        var matches = ALL_APPS.filter(function(m) {
          return (m.name        || '').toLowerCase().includes(q) ||
                 (m.category    || '').toLowerCase().includes(q) ||
                 (m.description || '').toLowerCase().includes(q);
        });

        if (!matches.length) {
          results.innerHTML = '<p class="py-2 px-3 text-muted">No applications found.</p>';
          return;
        }

        results.innerHTML = matches.map(function(m) {
          var badges = '';
          if (m.category) badges += '<span class="badge text-bg-secondary me-1">' + esc(m.category) + '</span>';
          if (m.gpu)      badges += '<span class="badge text-bg-success me-1">GPU</span>';
          var desc = m.description ? '<div class="small text-muted">' + esc(m.description) + '</div>' : '';
          return '<a href="' + scriptName + '/' + esc(m.dirname) + '" class="d-block text-decoration-none py-2 px-3 border-bottom">' +
                 '<div>' + badges + '<span class="fw-semibold">' + esc(m.name) + '</span></div>' +
                 desc + '</a>';
        }).join('');
      });
    })();
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous"></script>
    <!-- To prevent elements that are initially hidden from appearing for just a moment, make them visible after all loading is complete. -->
    <script>
      window.addEventListener('load', function() {
        document.body.style.visibility = 'visible';
      });
    </script>
  </body>
</html>
