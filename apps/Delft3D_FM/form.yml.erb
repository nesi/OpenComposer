<%# AI generated %>
<%
base_path = File.join(File.dirname(yml_path), '../SlurmBasic/form.yml')
base = read_yaml(base_path)

new_form = {}
base['form'].each do |k, v|
  if k == 'time_days_hours_minutes'
    new_form['delft3d_fm_module'] = {
      'widget' => 'module_load',
      'module' => "Delft3D_FM",
      'label'  => "Delft3D_FM Module"
    }

  end
  new_form[k] = v
end

base['form'] = new_form



base['script'] = base['script'].rstrip + "\n\n" + [
  "module -q purge",
  "module load #{delft3d_fm_module}",
  app_cmd
].join("\n") + "\n"
%>
<%= base.to_yaml -%>
