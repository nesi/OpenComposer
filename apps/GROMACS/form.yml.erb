<%
base_path = File.join(File.dirname(yml_path), '../SlurmGPU/form.yml')
base = YAML.load_file(base_path)

new_form = {}
base['form'].each do |k, v|
  if k == 'time_days_hours_minutes'
    new_form['gromacs_module'] = {
      'widget' => 'module_load',
      'module' => "GROMACS",
      'label'  => "GROMACS Module"
    }
    new_form['gromacs_parallelism'] = {
      'widget'  => 'radio',
      'label'   => 'Parallelism',
      'value'   => 'multi',
      'options' => [
        ['Multi Node (Hybrid)', 'multi', 'disable-gromacs_run_shared', 'enable-gromacs_run_multi', 'enable-number_of_nodes'],
        ['Shared Memory',       'shared', 'disable-gromacs_run_multi',  'enable-gromacs_run_shared', 'disable-number_of_nodes']
      ]
    }
    new_form['gromacs_run_shared'] = {
      'widget' => 'text',
      'label'  => 'Run Command',
      'value'  => 'srun gmx mdrun -ntomp ${SLURM_CPUS_PER_TASK} -s input.tpr -o trajectory.trr -c struct.gro -e energies.edr'
    }
    new_form['gromacs_run_multi'] = {
      'widget' => 'text',
      'label'  => 'Run Command',
      'value'  => 'srun gmx_mpi mdrun_mpi -ntomp ${SLURM_CPUS_PER_TASK} -nomp ${SLURM_NNODES} -s input.tpr -o trajectory.trr -c struct.gro -e energies.edr'
    }
  end
  new_form[k] = v
end

base['form']   = new_form
base['script'] = base['script'].rstrip + "\n\n" + <<~'APP_SCRIPT'
  module -q purge
  module load #{gromacs_module}

  #{gromacs_run_shared}
  #{gromacs_run_multi}
APP_SCRIPT
%>
<%= base.to_yaml -%>
