<% if @error_msg %>
  <div class="alert alert-warning alert-dismissible mx-1 mb-0">
    <%= @error_msg %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% end %>

<%= output_action_modal("CancelJob") %>
<%= output_action_modal("DeleteInfo") %>

<div class="modal" id="_historyCancelAll" aria-hidden="true" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <!-- Phase 1: confirmation -->
      <div id="_cancelAllPhase1">
        <div class="modal-body">
          Cancel <strong>all</strong> queued and running jobs?
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" tabindex="-1">No</button>
          <button type="button" class="btn btn-danger" tabindex="-1" onclick="ocHistory.startCancelAll()">Yes, cancel all</button>
        </div>
      </div>
      <!-- Phase 2: progress + abort -->
      <div id="_cancelAllPhase2" class="d-none">
        <div class="modal-body" id="_cancelAllProgressArea"></div>
        <div class="modal-footer">
          <button type="button" id="_cancelAllAbortBtn" class="btn btn-warning">Abort</button>
          <button type="button" id="_cancelAllCloseBtn" class="btn btn-secondary d-none" onclick="window.location.reload()">Close</button>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="modal" id="_historyDeleteAll" aria-hidden="true" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-body">
        Delete <strong>all</strong> job history? This cannot be undone.
      </div>
      <div class="modal-footer">
        <form action="<%= history_path_with_query %>" method="post">
          <input type="hidden" name="action" value="DeleteAll">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" tabindex="-1">No</button>
          <button type="submit" class="btn btn-primary" tabindex="-1">Yes, delete all</button>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="row px-3">
  <div class="bg-gradient" style="background:<%= @conf['description_color'] %>; color:<%= @conf['description_text_color'] %>;">
    <div class="d-flex justify-content-between align-items-end mb-2">
      <div>
        <%= output_action_badge("CancelJob") %>
        <%= output_action_badge("DeleteInfo") %>
        <button class="btn btn-sm" style="background-color:<%= @conf['history_action_color'] %>;border-color:<%= @conf['history_action_color'] %>;color:#fff;" data-bs-toggle="modal" data-bs-target="#_historyCancelAll">
          Cancel All Jobs
        </button>
        <button class="btn btn-sm" style="background-color:<%= @conf['history_action_color'] %>;border-color:<%= @conf['history_action_color'] %>;color:#fff;" data-bs-toggle="modal" data-bs-target="#_historyDeleteAll">
          Delete All History
        </button>
        <button class="btn btn-sm btn-secondary" onclick="window.location.reload()">
          <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
      </div>
      <div class="text-end">
        <div class="d-inline-block text-start" id="_historyFilterGroup">
        <form id="filterForm" onsubmit="ocHistory.applyFilter(); return false;" class="w-100">
          <% advanced_open = (@detail_open == 'true') %>
          <div class="my-3 w-100">
            <div id="_historyAdvancedWrapper">
              <div class="input-group w-100">
                <input type="text" class="form-control" aria-label="Filter" name="filter" value="<%= @filter %>" id="_filterInput">
                <button class="btn btn-warning" type="submit" aria-label="Search">
                  <i class="bi bi-search"></i>
                </button>
                <button
                  class="btn btn-secondary <%= advanced_open ? 'active' : '' %>"
                  type="button"
                  id="_historyAdvancedToggle"
                  aria-expanded="<%= advanced_open ? 'true' : 'false' %>"
                  aria-controls="_historyAdvancedSearch"
                >
                  Detail <i class="bi <%= advanced_open ? 'bi-chevron-up' : 'bi-chevron-down' %>" id="_historyAdvancedToggleIcon"></i>
                </button>
              </div>
            </div>
            <div id="_historyAdvancedSearch" class="<%= advanced_open ? 'mt-2' : 'd-none' %>">
              <div class="d-flex justify-content-start align-items-center mt-2">
                <div class="form-check form-check-inline mb-0">
                  <input class="form-check-input" type="radio" name="filter_mode" id="_historyFilterModeAnd" value="and" <%= 'checked' if @filter_mode != 'or' %>>
                  <label class="form-check-label" for="_historyFilterModeAnd">AND Search</label>
                </div>
                <div class="form-check form-check-inline mb-0">
                  <input class="form-check-input" type="radio" name="filter_mode" id="_historyFilterModeOr" value="or" <%= 'checked' if @filter_mode == 'or' %>>
                  <label class="form-check-label" for="_historyFilterModeOr">OR Search</label>
                </div>
              </div>
              <div class="mt-2">
                <div class="input-group">
                  <label class="input-group-text history-search-label" for="_historyFilterColumn">Field</label>
                  <select class="form-select" id="_historyFilterColumn" name="filter_column">
                    <% @filter_column_items.each do |value, label| %>
                      <option value="<%= value %>" <%= 'selected' if @filter_column == value %>><%= label %></option>
                    <% end %>
                  </select>
                </div>
              </div>
              <div class="mt-3">
                <div class="input-group">
                  <label class="input-group-text history-search-label" for="_historyDateRange">Range</label>
                  <select class="form-select" id="_historyDateRange" name="date_range">
                    <% @date_range_items.each do |value, label| %>
                      <option value="<%= value %>" <%= 'selected' if @date_range == value %>><%= label %></option>
                    <% end %>
                  </select>
                </div>
              </div>
              <div id="_historyCustomDates" class="d-flex justify-content-between gap-2 mt-3 <%= @date_range == 'custom' ? '' : 'd-none' %>">
                <div class="input-group">
                  <label class="input-group-text history-search-label" for="_historyDateFrom">From</label>
                  <input
                    type="date"
                    class="form-control"
                    id="_historyDateFrom"
                    name="date_from"
                    <%= @date_from && !@date_from.empty? ? "value=\"#{@date_from}\"" : "" %>
                  >
                </div>
                <div class="input-group">
                  <label class="input-group-text history-search-label" for="_historyDateTo">To</label>
                  <input
                    type="date"
                    class="form-control"
                    id="_historyDateTo"
                    name="date_to"
                    max="<%= Date.today.strftime('%Y-%m-%d') %>"
                    <%= @date_to && !@date_to.empty? ? "value=\"#{@date_to}\"" : "" %>
                  >
                </div>
              </div>
            </div>
          </div>
        </form>
        <div class="d-flex">
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="_historyStatusQueued" id="_historyStatusQueued" value="queued" <%= 'checked' if @statuses&.include?('queued') %>>
            <label class="form-check-label" for="_historyStatusQueued">Queued</label>
          </div>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="_historyStatusRunning" id="_historyStatusRunning" value="running" <%= 'checked' if @statuses&.include?('running') %>>
            <label class="form-check-label" for="_historyStatusRunning">Running</label>
          </div>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="_historyStatusCompleted" id="_historyStatusCompleted" value="completed" <%= 'checked' if @statuses&.include?('completed') %>>
            <label class="form-check-label" for="_historyStatusCompleted">Completed</label>
          </div>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="_historyStatusCancelled" id="_historyStatusCancelled" value="cancelled" <%= 'checked' if @statuses&.include?('cancelled') %>>
            <label class="form-check-label" for="_historyStatusCancelled">Cancelled</label>
          </div>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="_historyStatusFailed" id="_historyStatusFailed" value="failed" <%= 'checked' if @statuses&.include?('failed') %>>
            <label class="form-check-label" for="_historyStatusFailed">Failed</label>
          </div>
          <div class="form-check form-check-inline me-1">
            <input class="form-check-input" type="checkbox" name="_historyStatusUnknown" id="_historyStatusUnknown" value="unknown" <%= 'checked' if @statuses&.include?('unknown') %>>
            <label class="form-check-label" for="_historyStatusUnknown">Unknown</label>
          </div>
        </div>
        <% if @conf.key?("clusters") && @conf["clusters"].size > 1 %>
          <div class="d-flex mt-1">
            <% @conf["clusters"].each_key.with_index do |name, index| %>
              <% end_margin = index == @conf["clusters"].size - 1 ? "me-1" : "" %>
              <div class="form-check form-check-inline <%= end_margin %>">
                <input class="form-check-input" type="radio" name="_historyCluster" id="_historyCluster_<%= name %>" value="<%= name %>" <%= 'checked' if @cluster_name == name %>>
                <label class="form-check-label" for="_historyCluster_<%= name %>"><%= name %></label>
              </div>
            <% end %>
          </div>
        <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<% if @sacct_error %>
  <div class="alert alert-warning mx-3 mt-2 mb-0">
    <strong>sacct error:</strong> <%= escape_html(@sacct_error) %>
  </div>
<% end %>

<% show_output_col = @conf["history"].is_a?(Hash) && @conf["history"].key?("OC_HISTORY_OUTPUT_FILE") %>
<% show_error_col  = @conf["history"].is_a?(Hash) && @conf["history"].key?("OC_HISTORY_ERROR_FILE") %>

<% if @jobs.nil? || @jobs.empty? %>
  <div class="mt-3 ms-2">
    <p>(No Jobs)</p>
  </div>
<% else %>
  <% @jobs.each do |job| %>
    <%= output_job_id_modal(job, @filter) %>
    <% if job[JOB_DIR_NAME].to_s.strip.empty? %>
      <%= output_job_slurm_script_modal(job) %>
    <% else %>
      <%= output_job_script_modal(job, @filter) %>
    <% end %>
  <% end %>

  <div class="row px-3 table-responsive-sm">
    <table class="table table-bordered mb-0 text-nowrap table-hover">
      <thead>
        <tr class="table-primary text-center">
          <th><input class="form-check-input" type="checkbox" id="_historySelectAll" value="-1"></th>
          <th class="text-wrap text-break">
            <span>Job ID</span>
            <%= output_history_sort_controls(JOB_ID) %>
          </th>
          <th class="text-wrap text-break">
            <span>Application</span>
            <%= output_history_sort_controls(JOB_APP_NAME) %>
          </th>
          <th class="text-wrap text-break">
            <span>Script Location</span>
            <%= output_history_sort_controls(HEADER_SCRIPT_LOCATION) %>
          </th>
          <th class="text-wrap text-break">
            <span>Script Name</span>
            <%= output_history_sort_controls(HEADER_SCRIPT_NAME) %>
          </th>
          <th class="text-wrap text-break">
            <span>Job Name</span>
            <%= output_history_sort_controls(JOB_NAME) %>
          </th>
          <th class="text-wrap text-break d-none d-lg-table-cell">
            <span>Start Time</span>
            <%= output_history_sort_controls("Start") %>
          </th>
          <th class="text-wrap text-break d-none d-lg-table-cell">
            <span>End Time</span>
            <%= output_history_sort_controls("End") %>
          </th>
          <% if show_output_col %>
          <th class="text-wrap text-break d-none d-lg-table-cell">Output</th>
          <% end %>
          <% if show_error_col %>
          <th class="text-wrap text-break d-none d-lg-table-cell">Error</th>
          <% end %>
          <th class="text-wrap text-break">
            <span>Status</span>
            <%= output_history_sort_controls(JOB_STATUS_ID) %>
          </th>
        </tr>
      </thead>
      <tbody class="text-center" id="_historyTbody">
        <% cached_related_apps = {} %>
        <% @jobs.each do |job| %>
          <% job_id_filter       = history_highlight_filter(@filter, @filter_column, JOB_ID) %>
          <% app_name_filter     = history_highlight_filter(@filter, @filter_column, JOB_APP_NAME) %>
          <% script_loc_filter   = history_highlight_filter(@filter, @filter_column, HEADER_SCRIPT_LOCATION) %>
          <% script_name_filter  = history_highlight_filter(@filter, @filter_column, HEADER_SCRIPT_NAME) %>
          <% job_name_filter     = history_highlight_filter(@filter, @filter_column, JOB_NAME) %>
          <% job_details_modal_match = job_details_modal_matches_filter?(job, job_id_filter) %>
          <% job_script_modal_match  = job_script_modal_matches_filter?(job, script_name_filter) %>
          <tr data-status="<%= job[JOB_STATUS_ID] %>">
            <td class="table-primary">
              <input class="form-check-input" type="checkbox" id="ocJobId-<%= job[JOB_ID] %>" value="-1">
            </td>
            <td class="text-wrap text-break text-end history-modal-match-cell <%= 'history-modal-match-active' if job_details_modal_match %>">
              <a href="#" data-bs-toggle="modal" data-bs-target="#_historyJobId<%= job[JOB_ID] %>"><%= output_text(job[JOB_ID], job_id_filter) %></a>
            </td>
            <td class="text-wrap text-break">
              <% if !job[JOB_DIR_NAME].to_s.strip.empty? %>
                <a href="<%= File.join(@script_name.to_s, job[JOB_DIR_NAME].to_s) %>"><%= output_text(job[JOB_APP_NAME], app_name_filter) %></a>
                <% directory_path = File.join(@apps_dir.to_s, job[JOB_DIR_NAME].to_s) %>
                <% unless cached_related_apps.key?(directory_path) %>
                <%   related_apps = create_manifest(directory_path)&.related_apps %>
                <%   cached_related_apps[directory_path] = output_related_apps_icon(job[JOB_DIR_NAME].to_s, related_apps) %>
                <% end %>
                <% cached_related_apps[directory_path].each do |r| %>
                  <%= r %>
                <% end %>
              <% else %>
                <%= output_text(job[JOB_APP_NAME], app_name_filter) %>
              <% end %>
            </td>
            <td class="text-wrap text-break">
              <% unless job[HEADER_SCRIPT_LOCATION].to_s.strip.empty? %>
                <a target="_blank" href="<%= @my_ood_url %>/pun/sys/dashboard/files/fs<%= job[HEADER_SCRIPT_LOCATION] %>"><%= output_text(job[HEADER_SCRIPT_LOCATION], script_loc_filter) %></a>
                <% unless @login_node.nil? %>
                  <a style="color: black; text-decoration: none; vertical-align: middle;" target="_blank" href="<%= @my_ood_url %>/pun/sys/shell/ssh/<%= @login_node %>/<%= job[HEADER_SCRIPT_LOCATION] %>">
                    <i class="bi bi-terminal-fill fs-5"></i>
                  </a>
                <% end %>
              <% end %>
            </td>
            <td class="text-wrap text-break history-modal-match-cell <%= 'history-modal-match-active' if job_script_modal_match %>">
              <% if !job[HEADER_SCRIPT_NAME].to_s.strip.empty? %>
                <a href="#" data-bs-toggle="modal" data-bs-target="#_historyJobScript<%= job[JOB_ID] %>"><%= output_text(job[HEADER_SCRIPT_NAME], script_name_filter) %></a>
              <% else %>
                <a href="#" data-bs-toggle="modal" data-bs-target="#_historyJobScript<%= job[JOB_ID] %>">Job</a>
              <% end %>
            </td>
            <td class="text-wrap text-break"><%= output_text(job[JOB_NAME], job_name_filter) %></td>
            <td class="text-wrap text-break d-none d-lg-table-cell"><%= escape_html(job["Start"].to_s) %></td>
            <td class="text-wrap text-break d-none d-lg-table-cell"><%= escape_html(job["End"].to_s) %></td>
            <% if show_output_col %>
            <td class="text-wrap text-break d-none d-lg-table-cell">
              <% stdout_path = job["StdOut"].to_s.strip %>
              <% unless stdout_path.empty? %>
                <a href="#" title="<%= escape_html(stdout_path) %>" onclick="ocHistory.openFileOverlay('<%= escape_html(stdout_path) %>'); return false;"><%= escape_html(File.basename(stdout_path)) %></a>
              <% end %>
            </td>
            <% end %>
            <% if show_error_col %>
            <td class="text-wrap text-break d-none d-lg-table-cell">
              <% stderr_path = job["StdErr"].to_s.strip %>
              <% unless stderr_path.empty? %>
                <a href="#" title="<%= escape_html(stderr_path) %>" onclick="ocHistory.openFileOverlay('<%= escape_html(stderr_path) %>'); return false;"><%= escape_html(File.basename(stderr_path)) %></a>
              <% end %>
            </td>
            <% end %>
            <td class="text-wrap text-break"><%= output_status(job[JOB_STATUS_ID]) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<% if @jobs_size > 0 %>
<div class="row mt-2 mx-1">
  <div class="col text-start">
    <div>Showing <%= @start_index + 1 %> to <%= @end_index + 1 %> of <%= @jobs_size %> entries (<%= @history_search_elapsed_label %> sec.)</div>
    <div>Show
      <input type="number" id="_historyRows" value=<%= @rows %> style="width: 80px;" onkeydown="if(event.key === 'Enter') ocHistory.redirectWithRows()" >
      entries
    </div>
  </div>
  <div class="col text-center">
    <%= output_pagination(@current_page, @page_size, @rows) %>
  </div>
  <div class="col text-end"></div>
</div>
<% end %>

<% if show_output_col || show_error_col %>
<div class="modal" id="_historyFileOverlay" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-scrollable modal-xl">
    <div class="modal-content" style="resize: horizontal; padding-right: 16px;">
      <div class="modal-header">
        <h5 class="text-break" id="_historyFileOverlayTitle">File</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="_historyFileOverlayBody"></div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>
<% end %>

<script src="<%= @script_name %>/history.js"></script>
