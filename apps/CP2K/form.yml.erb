<%
base_path = File.join(File.dirname(yml_path), '../SlurmGPU/form.yml')
base = read_yaml(base_path)

new_form = {}
base['form'].each do |k, v|
  if k == 'time_days_hours_minutes'
    new_form['cp2k_module'] = {
      'widget' => 'module_load',
      'module' => "CP2K",
      'label'  => "CP2K Module"
    }
  end
  new_form[k] = v
end

base['form']   = new_form
base['script'] = base['script'].rstrip + "\n\n" + <<~'APP_SCRIPT'
  module -q purge
  module load #{cp2k_module}

  srun cp2k.psmp -i example.inp -o example.out
APP_SCRIPT
%>
<%= base.to_yaml -%>
