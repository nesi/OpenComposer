<% if @script_path %>
  <% script_link = "<a target=\"_blank\" href=\"#{@my_ood_url}/pun/sys/dashboard/files/fs#{File.dirname(@script_path)}\">#{@script_path}</a>" %>
  <% if @login_node %>
    <% script_link += " <a style=\"color: black; text-decoration: none; vertical-align: middle;\" target=\"_blank\" href=\"#{@my_ood_url}/pun/sys/shell/ssh/#{@login_node}/#{File.dirname(@script_path)}\"><i class=\"bi bi-terminal-fill fs-5\"></i></a>" %>
  <% end %>
  <% script_msg = "The script file is saved as #{script_link}." %>
<% end %>

<% if @job_id && @error_msg.nil? %>
  <div class="alert alert-success alert-dismissible mx-1 mb-0">
    Job was successfully submitted (Job ID is <code><%= @job_id %></code>).
    <%= script_msg %>
    <% if @conf.key?("clusters") && @conf["clusters"].size > 1 %>
      Go to the <a href="<%= @script_name %>/history?cluster=<%= @cluster_name %>">History page</a>.
    <% else %>
      Go to the <a href="<%= @script_name %>/history">History page</a>.
    <% end %>
    <button class="btn-close" data-bs-dismiss="alert"></button>
  </div>

<% elsif @error_msg %>
  <div class="alert alert-warning alert-dismissible mx-1 mb-0">
    Job submission failed. (<%= @error_msg %>)
    <button class="btn-close" data-bs-dismiss="alert"></button>
  </div>

<% elsif @script_path %>
  <div class="alert alert-info alert-dismissible mx-1 mb-0">
    <%= script_msg %>
    <button class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% end %>

<form id="<%= SUBMIT_FORM %>" action="<%= @current_path %>" method="post" onsubmit="return ocForm.submitEffect('<%= @form_action %>');">
  <div class="row px-3" style="color:<%= @conf['description_text_color'] %>;">
    <!-- Application Info Section -->
    <div class="col pt-2 pb-2 bg-gradient border-bottom" style="background:<%= @conf['description_color'] %>;">
      <div class="d-flex gap-3">
        <% if @manifest['icon'].to_s.strip != '' %>
          <% _is_bi_fa, _icon_src = get_icon_path(@manifest['dirname'], @manifest['icon']) %>
          <% _real_icon = _is_bi_fa || (_icon_src && !_icon_src.to_s.include?('app_default')) %>
          <% if _real_icon %>
            <div class="flex-shrink-0 d-flex align-items-center">
              <% if _is_bi_fa %>
                <i class="<%= ERB::Util.h(@manifest['icon']) %>" style="font-size:4rem; line-height:1;"></i>
              <% else %>
                <img src="<%= ERB::Util.h(_icon_src.to_s) %>" alt="" style="height:64px; width:auto; max-width:120px; object-fit:contain;">
              <% end %>
            </div>
          <% end %>
        <% end %>
        <div>
          <h3>
            <a href="<%= @script_name %>/<%= @manifest['dirname'] %>" class="fw-semibold" style="color: inherit; text-decoration: none;">
              <%= @manifest['name'] %>
            </a>
          </h3>
          <input type="hidden" name="<%= JOB_APP_NAME %>" value="<%= @manifest['name'] %>">
          <input type="hidden" name="<%= JOB_DIR_NAME %>" value="<%= @dir_name %>">
          <input type="hidden" name="_tmpl_icon" value="<%= ERB::Util.h(@manifest['icon'].to_s) %>">
          <p class="mb-1"><%= @manifest['description'] %></p>
          <% if @manifest['homepage'].to_s.strip != '' %>
            <p class="mb-0 small"><a href="<%= ERB::Util.h(@manifest['homepage']) %>" target="_blank" rel="noopener" style="color: inherit; opacity: 0.75;"><%= ERB::Util.h(@manifest['homepage']) %></a></p>
          <% end %>
          <% if @manifest['documentation'].to_s.strip != '' %>
            <p class="mb-0 small"><a href="<%= ERB::Util.h(@manifest['documentation']) %>" target="_blank" rel="noopener" style="color: inherit; opacity: 0.75;">NeSI Documentation</a></p>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Header -->
    <div class="col pt-2 pb-0 bg-gradient border-bottom" style="background: <%= @conf['description_color'] %>;">
      <%= output_header(@body, @header) %>
    </div>
  </div>

  <% _form_empty = @body["form"].nil? || @body["form"].empty? %>
  <div id="<%= FORM_LAYOUT %>" class="row <%= _form_empty ? 'row-cols-1' : 'row-cols-1 row-cols-lg-2' %> mx-1 bg-gradient" style="background: <%= @conf['form_color'] %>;">
    <!-- Form Body -->
    <% unless _form_empty %>
    <div class="col pt-3">
      <%= output_body(@body, @header, @manifest['name'], @manifest['dirname']) %>
    </div>
    <% end %>

    <!-- Script Content Section -->
    <div class="col py-3 d-flex flex-column">
      <label id="label_<%= OC_SCRIPT_CONTENT %>" class="fw-semibold" for="<%= OC_SCRIPT_CONTENT %>"><%= @script_label %></label>
      <div id="<%= OC_SCRIPT_CONTENT %>_editor" class="position-relative mt-1 mb-3 flex-grow-1">
        <pre id="<%= OC_SCRIPT_CONTENT %>_highlight_container" class="form-control mb-0" aria-hidden="true"><code id="<%= OC_SCRIPT_CONTENT %>_highlight" class="d-block"></code></pre>
        <textarea id="<%= OC_SCRIPT_CONTENT %>" name="<%= OC_SCRIPT_CONTENT %>" class="form-control position-relative mb-0" tabindex="<%= @table_index %>" accesskey="s" spellcheck="false" oninput="ocForm.updateHeight(ocForm.scriptArea); ocForm.storePreviousValue('<%= OC_SCRIPT_CONTENT %>'); ocForm.markScriptEdited(); ocForm.syncScriptHighlight()" required>(Something wrong)</textarea>
      </div>
      <!-- Submit Button -->
      <% unless @new_template %>
      <% if @form_action == "confirm" || @form_action == "confirm-save" %>
      <button class="btn btn-primary d-block w-100" id="<%= SUBMIT_BUTTON %>" type="button" data-bs-toggle="modal" data-bs-target="#modal-<%= SUBMIT_CONFIRM %>" tabindex="<%= @table_index + 1 %>">
        Confirm
      </button>
      <% else %>
      <input type="submit" class="btn btn-primary d-block w-100" id="<%= SUBMIT_BUTTON %>" value="<%= @form_action.capitalize %>" tabindex="<%= @table_index + 1 %>">
      <% end %>
      <% end %>
      <div class="modal fade" id="modal-<%= SUBMIT_CONFIRM %>" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg" style="overflow-y: initial !important;">
          <div class="modal-content">
            <div class="modal-body" style="max-height: 80vh; overflow-y: auto;">
              <div class="container-fluid">
                <div class="row">
                  <div class="col">
                    <div id="<%= SUBMIT_CONTENT %>_editor" class="position-relative w-100">
                      <pre id="<%= SUBMIT_CONTENT %>_highlight_container" class="form-control mb-0" aria-hidden="true"><code id="<%= SUBMIT_CONTENT %>_highlight" class="d-block"></code></pre>
                      <textarea id="<%= SUBMIT_CONTENT %>" name="<%= SUBMIT_CONTENT %>" class="form-control position-relative mb-0 w-100" rows="6" spellcheck="false" oninput="ocForm.updateHeight(ocForm.submitArea); ocForm.storePreviousValue('<%= SUBMIT_CONTENT %>'); ocForm.syncSubmitHighlight()">(Something Wrong)</textarea>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="modal-footer">
              <button class="btn btn-secondary" data-bs-dismiss="modal" type="button">Close</button>
              <% if @form_action == "confirm" %>
              <button class="btn btn-primary" form="<%= SUBMIT_FORM %>" type="submit">Submit</button>
              <% elsif @form_action == "confirm-save" %>
              <button class="btn btn-primary" form="<%= SUBMIT_FORM %>" type="submit">Save</button>
              <% end %>
            </div>
          </div>
        </div>
      </div>
      <!-- Save / Save as Custom Template Button -->
      <% if @template_slug %>
      <button type="button" class="btn <%= @new_template ? 'btn-primary' : 'btn-outline-secondary mt-2' %> d-block w-100"
              onclick="ocSaveTemplateOverwrite()">
        Save
      </button>
      <% else %>
      <button type="button" class="btn <%= @new_template ? 'btn-primary' : 'btn-outline-secondary mt-2' %> d-block w-100"
              data-bs-toggle="modal" data-bs-target="#modal-save-template">
        Save as Custom Template
      </button>
      <% end %>
    </div>
  </div>
</form>

<!-- Save as Custom Template Modal -->
<div class="modal fade" id="modal-save-template" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Save as Custom Template</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label fw-semibold" for="tmpl-name-input">Template Name</label>
          <input type="text" id="tmpl-name-input" class="form-control" placeholder="e.g. My GPU Job">
        </div>
        <div class="mb-1">
          <label class="form-label" for="tmpl-desc-input">Description <span class="text-muted fw-normal">(optional)</span></label>
          <input type="text" id="tmpl-desc-input" class="form-control" placeholder="Brief description">
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal" type="button">Cancel</button>
        <button class="btn btn-primary" type="button" onclick="ocSaveTemplate()">Save</button>
      </div>
    </div>
  </div>
</div>
<form id="save-template-form" method="post" action="<%= @script_name %>/templates"></form>
<% if @template_slug %>
<form id="save-template-overwrite-form" method="post" action="<%= @script_name %>/templates/<%= ERB::Util.u(@template_slug) %>/overwrite"></form>
<% end %>
<script>
<% if @template_slug %>
function ocSaveTemplateOverwrite() {
  var form = document.getElementById('save-template-overwrite-form');
  form.innerHTML = '';
  function addHidden(n, v) {
    var inp = document.createElement('input');
    inp.type = 'hidden'; inp.name = n; inp.value = v;
    form.appendChild(inp);
  }
  var mainForm = document.getElementById('<%= SUBMIT_FORM %>');
  var data = new FormData(mainForm);
  data.forEach(function(val, key) {
    if (key !== 'splat') addHidden(key, val);
  });
  form.submit();
}
<% end %>
function ocSaveTemplate() {
  var name = document.getElementById('tmpl-name-input').value.trim();
  if (!name) { document.getElementById('tmpl-name-input').focus(); return; }

  var form = document.getElementById('save-template-form');
  form.innerHTML = '';

  function addHidden(n, v) {
    var inp = document.createElement('input');
    inp.type = 'hidden'; inp.name = n; inp.value = v;
    form.appendChild(inp);
  }

  addHidden('template_name', name);
  addHidden('template_description', document.getElementById('tmpl-desc-input').value.trim());

  var mainForm = document.getElementById('<%= SUBMIT_FORM %>');
  var data = new FormData(mainForm);
  data.forEach(function(val, key) {
    if (key !== 'splat') addHidden(key, val);
  });

  form.submit();
}
</script>

<script>
var ocForm = ocForm || {};
ocForm.scriptArea = document.getElementById('<%= OC_SCRIPT_CONTENT %>');
ocForm.scriptHighlightContainer = document.getElementById('<%= OC_SCRIPT_CONTENT %>_highlight_container');
ocForm.scriptHighlight = document.getElementById('<%= OC_SCRIPT_CONTENT %>_highlight');
ocForm.submitArea = document.getElementById('<%= SUBMIT_CONTENT %>');
ocForm.submitHighlightContainer = document.getElementById('<%= SUBMIT_CONTENT %>_highlight_container');
ocForm.submitHighlight = document.getElementById('<%= SUBMIT_CONTENT %>_highlight');
</script>
<script src="<%= @script_name %>/form.js"></script>
<script>
ocForm.scriptLinePatterns = [];
ocForm.enabledBy = {};
<%= @js["script_patterns"].chomp %>
</script>
<script>
// Executes functions that should run once.
ocForm.onceExec = function() {
<%= @js["once"].chomp %>
};

// Execute dynamic form widgets.
ocForm.execDynamicWidget = function(fromId) {
  <%= @js["init_dw"].lines.map(&:chomp).sort.uniq.join("\n") %>

  <%= @js["exec_dw"].chomp %>
};

// Update the script section.
ocForm.updateScriptContents = function(selectedValues) {
  <%= @js["script"].chomp %>
};

// Update the submit section.
ocForm.updateSubmitContents = function(selectedValues) {
  <%= @js["submit"].chomp %>
};

// Rewrap scheduler directive lines after highlight.js tokenization.
ocForm.decorateSchedulerDirectives = function(area, highlight) {
  if (!area || !highlight) return;
  const directivePattern = /^(?:#(?:PJM|SBATCH|PBS)\b|#\$)/;
  const sourceLines = area.value.split('\n');
  const highlightedLines = highlight.innerHTML.split('\n');

  highlight.innerHTML = highlightedLines.map((lineHtml, index) => {
    const sourceLine = sourceLines[index] || '';
    if (!directivePattern.test(sourceLine.trimStart())) return lineHtml;

    return `<span class="oc-scheduler-directive">${lineHtml}</span>`;
  }).join('\n');
};

// Sync the caret color to the base text color of the highlighted code.
ocForm.syncCaretColor = function(area, highlight) {
  if (!area || !highlight) return;

  const color = window.getComputedStyle(highlight).color;
  if (color) {
    area.style.caretColor = color;
  }
};

// Sync a textarea content to the corresponding highlight area.
ocForm.syncHighlight = function(area, highlight) {
  if (!area || !highlight) return;

  highlight.textContent = area.value;
  highlight.removeAttribute('data-highlighted');
  hljs.highlightElement(highlight);
  ocForm.decorateSchedulerDirectives(area, highlight);
  ocForm.syncCaretColor(area, highlight);
};

// Mark that the user has started editing the script (hides the write-here hint).
ocForm.markScriptEdited = function() {
  ocForm.scriptEdited = true;
};

// Sync the script textarea content to the highlight area.
ocForm.syncScriptHighlight = function() {
  ocForm.syncHighlight(ocForm.scriptArea, ocForm.scriptHighlight);
  if (!ocForm.scriptEdited && ocForm.scriptHighlight) {
    const hint = document.createElement('span');
    hint.className = 'oc-script-placeholder-hint';
    hint.textContent = '\n\n(write your slurm script here)';
    ocForm.scriptHighlight.appendChild(hint);
  }
};

// Sync the submit textarea content to the highlight area.
ocForm.syncSubmitHighlight = function() {
  ocForm.syncHighlight(ocForm.submitArea, ocForm.submitHighlight);
};

// Keep the highlight overlay visibility in sync with the textarea.
ocForm.syncScriptHighlightVisibility = function() {
  if (!ocForm.scriptArea || !ocForm.scriptHighlightContainer) return;

  const isHidden = getComputedStyle(ocForm.scriptArea).display === 'none';
  ocForm.scriptHighlightContainer.style.display = isHidden ? 'none' : '';
};

ocForm.refreshEditorLayout = function() {
  ocForm.updateHeight(ocForm.scriptArea);
  ocForm.updateHeight(ocForm.submitArea);
  ocForm.syncScriptHighlight();
  ocForm.syncSubmitHighlight();
  ocForm.syncScriptHighlightVisibility();
};

// Check if a cache file exists.
ocForm.isScriptCache = function() {
  return <%= @script_content != nil %>;
};

ocForm.isSubmitCache = function() {
  return <%= @submit_content != nil %>;
};

// Load cache file contents.
// Since @script_content uses escape_html() in ruby, it is converted using textarea to decode.
ocForm.loadScriptCache = function() {
  const textarea = document.createElement('textarea');
  textarea.innerHTML = <%= @script_content.to_json %>;
  return textarea.value;
};

// Load cache file contents.
// Since @submit_content uses escape_html() in ruby, it is converted using textarea to decode.
ocForm.loadSubmitCache = function() {
  const textarea = document.createElement('textarea');
  textarea.innerHTML = <%= @submit_content.to_json %>;
  return textarea.value;
};

// Prevent default behavior for Enter key unless specific elements are focused.
document.addEventListener('keydown', function(event) {
  if (event.key === 'Enter' && (event.target.id !== '<%= OC_SCRIPT_CONTENT %>' && event.target.id !== '<%= SUBMIT_BUTTON %>' && event.target.id !== '<%= SUBMIT_CONTENT %>')) {
    event.preventDefault();
  }
});

ocForm.emptyScriptWarning = <%= @conf.fetch('empty_script_warning', true) ? 'true' : 'false' %>;
ocForm.previousScript = ""
ocForm.multiSelectDisabledIndexes = {};
ocForm.previousValues = {};
ocForm.previousRadioValues = {};

// Save the current value of a form element before modification.
ocForm.storePreviousValue = function(id) {
  const element = document.getElementById(id);
  if (!element) return;

  if (element.type === "radio") {
    let previous = ocForm.previousValues[element.name];
    if (previous === undefined) {
      const radios = document.querySelectorAll(`input[name="${element.name}"]`);
      radios.forEach(r => {
        if (r.defaultChecked) previous = r.id;
      });
    }

    ocForm.previousValues[element.name] = element.id;
    ocForm.previousRadioValues[element.name] = previous;
  }
  else {
    ocForm.previousValues[id] = element.value;
  }
};

// content_type is "both", "script" or "submit"
ocForm.updateArea = function(content_type, id = null) {
  let submitValues = [];

  ocForm.execDynamicWidget(id);

  if (content_type === "both" || content_type === "script") {
    ocForm.patchScript();
  }

  if (content_type === "both" || content_type === "submit") {
    ocForm.updateSubmitContents(submitValues);
    const newGeneratedSubmit = Object.values(submitValues).join('\n');
    ocForm.submitArea.value = newGeneratedSubmit;
    ocForm.updateHeight(ocForm.submitArea);
    ocForm.syncSubmitHighlight();
  }
};

window.onload = function() {
  let scriptValues = [];
  let submitValues = [];

  // Restore remembered last values from localStorage.
  // Skip when the server already pre-selected values from a template or history load.
  (function() {
    var sp = new URLSearchParams(window.location.search);
    if (!sp.has('template') && !sp.has('jobId')) {
      document.querySelectorAll('select[data-remember-last]').forEach(function(el) {
        var saved = localStorage.getItem('oc_last_' + el.id);
        if (saved == null) return;
        var idx = Array.from(el.options).findIndex(function(o) { return o.value === saved; });
        if (idx >= 0) el.selectedIndex = idx;
      });
    }
    document.addEventListener('change', function(e) {
      var el = e.target;
      if (el.tagName === 'SELECT' && el.dataset.rememberLast) {
        localStorage.setItem('oc_last_' + el.id, el.options[el.selectedIndex].value);
      }
    });
  })();

  ocForm.execDynamicWidget();
  ocForm.onceExec();
  ocForm.updateScriptContents(scriptValues);
  ocForm.updateSubmitContents(submitValues);
  const generatedScript = Object.values(scriptValues).join('\n');
  const generatedSubmit = Object.values(submitValues).join('\n');
  ocForm.scriptArea.value = ocForm.isScriptCache() ? ocForm.loadScriptCache() : generatedScript;
  ocForm.scriptEdited = ocForm.isScriptCache();
  ocForm.submitArea.value = ocForm.isSubmitCache() ? ocForm.loadSubmitCache() : generatedSubmit;
  ocForm.refreshEditorLayout();

  // When loaded from history (?jobId=) with a pre-fetched script, parse the script
  // directives into the left-panel widgets so they match the loaded script's inputs.
  if (new URLSearchParams(window.location.search).has('jobId') && ocForm.isScriptCache()) {
    ocForm.parseScriptToWidgets();
    ocForm.refreshEditorLayout();
  }

  var _ocExtKey = new URLSearchParams(window.location.search).get('ocExtLoad');
  if (_ocExtKey) {
    var _ocExtRaw = sessionStorage.getItem(_ocExtKey);
    sessionStorage.removeItem(_ocExtKey);
    if (_ocExtRaw !== null && ocForm.scriptArea) {
      var _ocExtPayload = null;
      try { _ocExtPayload = JSON.parse(_ocExtRaw); } catch (e) { _ocExtPayload = null; }
      var _ocSetField = function(id, val) {
        if (val === undefined || val === null || val === '') return;
        var el = document.getElementById(id);
        if (el) el.value = val;
      };
      if (_ocExtPayload && typeof _ocExtPayload === 'object' && !Array.isArray(_ocExtPayload)) {
        // Payload from the History page: script content plus header fields.
        ocForm.scriptArea.value = _ocExtPayload.script || '';
        ocForm.scriptEdited = true;
        _ocSetField('<%= HEADER_SCRIPT_LOCATION %>', _ocExtPayload.scriptLocation);
        _ocSetField('<%= HEADER_SCRIPT_NAME %>', _ocExtPayload.scriptName);
        _ocSetField('<%= HEADER_JOB_NAME %>', _ocExtPayload.jobName);
      } else {
        // Backward compatibility: payload is the raw script string.
        ocForm.scriptArea.value = _ocExtRaw;
      }
      ocForm.parseScriptToWidgets();
      ocForm.execDynamicWidget();
      ocForm.refreshEditorLayout();
    }
  }

  if (ocForm.scriptArea) {
    ocForm.scriptArea.addEventListener('input', ocForm.debouncedParseScript);
  }

  window.addEventListener('resize', () => {
    window.requestAnimationFrame(() => ocForm.refreshEditorLayout());
  });

  const submitModal = document.getElementById('modal-<%= SUBMIT_CONFIRM %>');
  if (submitModal) {
    // The modal content size is finalized only after it is shown.
    submitModal.addEventListener('shown.bs.modal', () => {
      ocForm.refreshEditorLayout();
    });
  }
};
</script>
