<%
base_path = File.join(File.dirname(yml_path), '../SlurmGPU/form.yml')
base = read_yaml(base_path)

new_form = {}
base['form'].each do |k, v|
  if k == 'time_days_hours_minutes'
    new_form['relion_module'] = {
      'widget' => 'module_load',
      'module' => "Relion",
      'label'  => "Relion Module"
    }
  end
  new_form[k] = v
end

base['form']   = new_form
base['script'] = base['script'].rstrip + "\n\n" + <<~'APP_SCRIPT'
  module -q purge
  module load #{relion_module}

  srun relion_run_ctffind_mpi ...
APP_SCRIPT
%>
<%= base.to_yaml -%>
