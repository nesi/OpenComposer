<%
base_path = File.join(File.dirname(yml_path), '../SlurmBasic/form.yml')
base = read_yaml(base_path)

new_form = {}
base['form'].each do |k, v|
  if k == 'time_days_hours_minutes'
    new_form['java_module'] = {
      'widget' => 'module_load',
      'module' => "Java",
      'label'  => "Java Module"
    }
  end
  new_form[k] = v
end

base['form']   = new_form
base['script'] = base['script'].rstrip + "\n\n" + <<~'APP_SCRIPT'
  module -q purge
  module load #{java_module}

  # The following line is needed in case your Java application
  # is called indirectly
  export _JAVA_OPTIONS=-Djava.io.tmpdir=${TMPDIR}
  java -Xmx3g -Djava.io.tmpdir=${TMPDIR} -jar /path/to/foo.jar
APP_SCRIPT
%>
<%= base.to_yaml -%>
