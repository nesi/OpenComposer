<iframe
  id="oc-frame"
  src="/pun/sys/opencomposer/"
  style="width:100%; border:none; display:block;"
  title="Open Composer">
</iframe>

<script>
  (function () {
    var frame = document.getElementById('oc-frame');
    function resize() {
      var top = frame.getBoundingClientRect().top + window.scrollY;
      frame.style.height = (window.innerHeight - top) + 'px';
    }
    resize();
    window.addEventListener('resize', resize);
  })();
</script>
