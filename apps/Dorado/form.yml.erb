<%
base_path = File.join(File.dirname(yml_path), '../SlurmGPU/form.yml')
base = YAML.load_file(base_path)

new_form = {}
base['form'].each do |k, v|
  if k == 'time_days_hours_minutes'
    new_form['dorado_module'] = {
      'widget' => 'module_load',
      'module' => 'Dorado',
      'label'  => 'Dorado Module'
    }
  end
  new_form[k] = v
end

base['form']   = new_form
base['script'] = base['script'].rstrip + "\n\n" + <<~'APP_SCRIPT'
  module -q purge
  module load #{dorado_module}

  dorado download --model dna_r10.4.1_e8.2_400bps_hac@v4.1.0

  DORADO_ARGS="${SLURM_GPUS_PER_NODE:+--device cuda:all}"
  dorado basecaller $DORADO_ARGS dna_r10.4.1_e8.2_400bps_hac@v4.1.0 pod5s/ > calls.bam
APP_SCRIPT
%>
<%= base.to_yaml -%>
