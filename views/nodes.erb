<div class="row px-3">
  <div class="bg-gradient" style="background:<%= @conf['description_color'] %>; color:<%= @conf['description_text_color'] %>;">
    <div class="d-flex justify-content-between align-items-center py-2">
      <div>
        <button class="btn btn-sm btn-secondary" onclick="window.location.reload()">
          <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
      </div>
      <% if @conf.key?("clusters") && @conf["clusters"].size > 1 %>
        <div class="d-flex">
          <% @conf["clusters"].each_key.with_index do |name, index| %>
            <% end_margin = index == @conf["clusters"].size - 1 ? "me-1" : "" %>
            <div class="form-check form-check-inline <%= end_margin %>">
              <input class="form-check-input" type="radio" name="_nodesCluster" id="_nodesCluster_<%= name %>" value="<%= name %>" <%= 'checked' if @cluster_name == name %>>
              <label class="form-check-label" for="_nodesCluster_<%= name %>"><%= name %></label>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<% if @nodes_error %>
  <div class="alert alert-warning mx-3 mt-2 mb-0">
    <strong>sinfo error:</strong> <%= escape_html(@nodes_error) %>
  </div>
<% end %>

<% if @nodes.nil? || @nodes.empty? %>
  <% unless @nodes_error %>
    <div class="mt-3 ms-2">
      <p>(No nodes)</p>
    </div>
  <% end %>
<% else %>
  <div class="row px-3 mt-2 table-responsive-sm">
    <table class="table table-bordered mb-0 table-hover text-nowrap">
      <thead>
        <tr class="table-primary text-center">
          <th class="text-start">Node</th>
          <th>State</th>
          <th>CPUs (A/I/O/T)</th>
          <th>Memory (MB)</th>
          <th>Free Mem (MB)</th>
          <th class="text-start">GRES</th>
          <th class="text-start">GRES Used</th>
        </tr>
      </thead>
      <tbody class="text-center">
        <% @nodes.each do |cols| %>
          <% node, state, cpus, mem, freemem, gres, gres_used = cols %>
          <%
            state_key = state.to_s.downcase.delete('*').strip
            badge_class = case state_key
            when 'idle'                       then 'bg-success'
            when 'allocated', 'alloc'         then 'bg-primary'
            when 'mixed'                      then 'bg-warning text-dark'
            when 'down', 'fail', 'not_responding' then 'bg-danger'
            when 'draining', 'drain'          then 'bg-warning text-dark'
            when 'drained'                    then 'bg-secondary'
            when 'completing', 'comp'         then 'bg-primary'
            when 'reserved', 'resv'           then 'bg-info text-dark'
            when 'maint', 'maintenance'       then 'bg-info text-dark'
            else                                   'bg-secondary'
            end
            gres_display      = (gres.to_s.strip == '(null)' || gres.to_s.strip.empty?)      ? '' : gres
            gres_used_display = (gres_used.to_s.strip == '(null)' || gres_used.to_s.strip.empty?) ? '' : gres_used
          %>
          <tr>
            <td class="text-start"><%= escape_html(node) %></td>
            <td><span class="badge <%= badge_class %>"><%= escape_html(state) %></span></td>
            <td><%= escape_html(cpus) %></td>
            <td><%= escape_html(mem) %></td>
            <td><%= escape_html(freemem) %></td>
            <td class="text-start"><%= escape_html(gres_display) %></td>
            <td class="text-start"><%= escape_html(gres_used_display) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<script>
document.querySelectorAll('input[name="_nodesCluster"]').forEach(function(radio) {
  radio.addEventListener('change', function() {
    var url = new URL(window.location.href);
    url.searchParams.set('cluster', radio.value);
    window.location.href = url.toString();
  });
});
</script>
