<%
base_path = File.join(File.dirname(yml_path), '../SlurmGPU/form.yml')
base = read_yaml(base_path)

# Use hide- (not disable-) so getValue still works on the hidden field.
# set-value programmatically switches between "" and "--device cuda:all "
# without exposing any form widget to the user.
if base['form']['gpu_any']
  base['form']['gpu_any']['options'] = base['form']['gpu_any']['options'].map do |opt|
    label, value, *rest = opt
    if value.to_s.empty?
      [label, value, *rest, 'hide-dorado_gpu_args', {'set-value-dorado_gpu_args' => ''}]
    else
      [label, value, *rest, 'hide-dorado_gpu_args', {'set-value-dorado_gpu_args' => '--device cuda:all '}]
    end
  end
end

new_form = {}
base['form'].each do |k, v|
  if k == 'time_days_hours_minutes'
    new_form['dorado_module'] = {
      'widget' => 'module_load',
      'module' => 'Dorado',
      'label'  => 'Dorado Module'
    }
    new_form['dorado_gpu_args'] = {
      'widget' => 'text',
      'label'  => '',
      'value'  => ''
    }
  end
  new_form[k] = v
end

base['form']   = new_form
base['script'] = base['script'].rstrip + "\n\n" + <<~'APP_SCRIPT'
  module -q purge
  module load #{dorado_module}

  # This is the command you need to run if you need to download the dorado database for the first time. 
  # dorado download --model dna_r10.4.1_e8.2_400bps_hac@v4.1.0

  # Main command to run
  dorado basecaller #{:dorado_gpu_args}dna_r10.4.1_e8.2_400bps_hac@v4.1.0 pod5s/ > calls.bam
APP_SCRIPT
%>
<%= base.to_yaml -%>
