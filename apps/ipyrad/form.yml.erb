<%
base_path = File.join(File.dirname(yml_path), '../SlurmBasic/form.yml')
base = read_yaml(base_path)

new_form = {}
base['form'].each do |k, v|
  if k == 'time_days_hours_minutes'
    new_form['ipyrad_module'] = {
      'widget' => 'module_load',
      'module' => "ipyrad",
      'label'  => "ipyrad Module"
    }
  end
  new_form[k] = v
end

base['form']   = new_form
base['script'] = base['script'].rstrip + "\n\n" + <<~'APP_SCRIPT'
  module -q purge
  module load #{ipyrad_module}

  # Before running this script, see https://docs.nesi.org.nz/Software/Available_Applications/ipyrad/#getting-started
  # for information about getting started with ipyrad.
  # This provides info on how to get "data1"

  ## assembly name
  assembly_name="data1"

  ## create, prepare and change to a job specific dir
  jobdir="ipyrad_${SLURM_JOB_ID}"
  params="params-${assembly_name}.txt"

  mkdir $jobdir
  sed "s#$(pwd) #$(pwd)/$jobdir#" $params > $jobdir/$params
  cd $jobdir

  ## call ipyrad on your params file and perform 7 steps from the workflow
  srun ipyrad -p $params -s NO_OF_STEPS --force 
APP_SCRIPT
%>
<%= base.to_yaml -%>