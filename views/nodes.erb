<div class="container-fluid mt-3 px-3">

  <%# ── Header ─────────────────────────────────────────────────── %>
  <div class="d-flex justify-content-between align-items-center mb-2">
    <h4 class="mb-0">Node Status</h4>
    <div class="d-flex align-items-center gap-2">
      <% if @conf.key?("clusters") && @conf["clusters"].size > 1 %>
        <% @conf["clusters"].each_key do |name| %>
          <div class="form-check form-check-inline mb-0">
            <input class="form-check-input nodes-cluster-radio" type="radio"
                   name="_nodesCluster" id="_nodesCluster_<%= name %>"
                   value="<%= name %>" <%= 'checked' if @cluster_name == name %>>
            <label class="form-check-label small" for="_nodesCluster_<%= name %>"><%= name %></label>
          </div>
        <% end %>
      <% end %>
      <span class="text-muted small" id="_nodesFetchedAt"></span>
      <div class="form-check form-switch mb-0">
        <input class="form-check-input" type="checkbox" id="_nodesAutoRefresh" style="cursor:pointer;">
        <label class="form-check-label small" for="_nodesAutoRefresh">Auto-refresh (30s)</label>
      </div>
      <a href="<%= @script_name %>/nodes" class="btn btn-sm btn-outline-secondary">&#8635; Refresh</a>
    </div>
  </div>

  <%# ── Loading indicator ───────────────────────────────────────── %>
  <div id="_nodesLoading" class="text-center py-5">
    <div class="spinner-border text-secondary" role="status">
      <span class="visually-hidden">Loading…</span>
    </div>
    <p class="text-muted mt-2 small">Fetching nodes…</p>
  </div>

  <%# ── Error ──────────────────────────────────────────────────── %>
  <div id="_nodesErrorAlert" class="alert alert-danger" style="display:none;"></div>

  <%# ── Content ─────────────────────────────────────────────────── %>
  <div id="_nodesContent" style="display:none;">

    <%# ── Summary badges ──────────────────────────────────────────── %>
    <div class="d-flex gap-2 flex-wrap mb-2 align-items-center" id="_nodesSummary"></div>

    <%# ── Filter bar ──────────────────────────────────────────────── %>
    <div class="card mb-2 border-secondary-subtle">
      <div class="card-body py-2">

        <div class="d-flex flex-wrap gap-3 align-items-center">

          <%# Search %>
          <div class="input-group input-group-sm" style="width:220px;">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" id="_nodesSearch" class="form-control" placeholder="Search node…">
          </div>

          <%# State filters – populated by JS %>
          <div id="_nodesStatesSection" style="display:none;">
            <div class="d-flex flex-wrap gap-1 align-items-center">
              <span class="text-muted small me-1">State:</span>
              <div id="_nodesStatesList" class="d-flex flex-wrap gap-1"></div>
            </div>
          </div>

        </div>

      </div>
    </div>

    <%# ── Count ──────────────────────────────────────────────────── %>
    <p class="text-muted small mb-1">
      Showing <strong><span id="_nodesCount">0</span></strong>
      of <span id="_nodesTotal">0</span> node(s)
    </p>

    <%# ── Table ──────────────────────────────────────────────────── %>
    <div class="table-responsive">
      <table id="_nodesTable" class="table table-bordered table-hover table-sm mb-1">
        <thead class="table-light">
          <tr>
            <th data-col="0" class="user-select-none" style="white-space:nowrap;">Node <span class="text-muted nodes-sort-neutral" style="font-size:.7em;">⇅</span></th>
            <th data-col="1" class="user-select-none" style="white-space:nowrap;">State <span class="text-muted nodes-sort-neutral" style="font-size:.7em;">⇅</span></th>
            <th data-col="2" class="user-select-none" style="white-space:nowrap;">CPUs <span class="text-muted nodes-sort-neutral" style="font-size:.7em;">⇅</span></th>
            <th data-col="3" class="user-select-none" style="white-space:nowrap;">Memory <span class="text-muted nodes-sort-neutral" style="font-size:.7em;">⇅</span></th>
          </tr>
        </thead>
        <tbody id="_nodesTbody"></tbody>
      </table>
    </div>

    <p id="_nodesEmpty" class="text-muted" style="display:none;">No nodes match the current filters.</p>

  </div>

</div>

<script>
(function() {
  var CLUSTER  = '<%= escape_html(@cluster_name.to_s) %>';
  var DATA_URL = '<%= @script_name %>/nodes/data';

  var tbody      = document.getElementById('_nodesTbody');
  var countEl    = document.getElementById('_nodesCount');
  var totalEl    = document.getElementById('_nodesTotal');
  var emptyEl    = document.getElementById('_nodesEmpty');
  var searchEl   = document.getElementById('_nodesSearch');
  var loadingEl  = document.getElementById('_nodesLoading');
  var contentEl  = document.getElementById('_nodesContent');
  var errorEl    = document.getElementById('_nodesErrorAlert');
  var fetchedEl  = document.getElementById('_nodesFetchedAt');
  var summaryEl  = document.getElementById('_nodesSummary');

  var allRows    = [];
  var gresTypes  = [];
  var sortCol    = null;
  var sortAsc    = true;
  var totalNodes = 0;

  function escHtml(s) {
    var d = document.createElement('div');
    d.appendChild(document.createTextNode(String(s)));
    return d.innerHTML;
  }

  function nodeStateBadge(state) {
    var s = (state || '').toLowerCase();
    var css;
    if      (s === 'idle')                            css = 'success';
    else if (s === 'allocated')                       css = 'primary';
    else if (s === 'mixed')                           css = 'warning text-dark';
    else if (s === 'down' || s === 'down*')           css = 'danger';
    else if (s === 'drained' || s === 'drained*')     css = 'secondary';
    else if (s === 'draining')                        css = 'warning text-dark';
    else if (s === 'maintenance' || s === 'reserved') css = 'info text-dark';
    else if (s === 'planned')                         css = 'primary';
    else                                              css = 'secondary';
    return '<span class="badge bg-' + css + '">' + escHtml(state) + '</span>';
  }

  // Parse a GRES string into { type: { subtype: { val, unit } } }.
  // Strips "(IDX:...)" annotations; handles "gpu:a100:4", "gpu:4", "nvme:1000G".
  function parseGresMap(gresStr) {
    var result = {};
    (gresStr || '').replace(/\([^)]*\)/g, '').split(',').forEach(function(e) {
      e = e.trim();
      if (!e) return;
      var parts = e.split(':');
      var type, sub, valStr;
      if (parts.length >= 3) {
        type = parts[0]; sub = parts[1]; valStr = parts[2];
      } else if (parts.length === 2) {
        type = parts[0]; sub = ''; valStr = parts[1];
      } else { return; }
      var m = valStr.match(/^(\d+)([TGMK]?)$/i);
      if (!m) return;
      if (!result[type]) result[type] = {};
      var unit = m[2].toUpperCase();
      if (!result[type][sub]) result[type][sub] = { val: 0, unit: unit };
      result[type][sub].val += parseInt(m[1], 10);
    });
    return result;
  }

  function formatGresVal(val, unit) {
    if      (unit === 'T') return val + ' TB';
    else if (unit === 'G') return val + ' GB';
    else if (unit === 'M') return val + ' MB';
    else if (unit === 'K') return val + ' KB';
    else                   return String(val);
  }

  // Build the cell HTML for one GRES type column given the node's total and used maps.
  function gresCellHtml(totalSubs, usedSubs) {
    var subtypes = Object.keys(totalSubs || {});
    if (!subtypes.length) return '<span class="text-muted small">—</span>';
    var html = '';
    subtypes.forEach(function(sub) {
      var t = totalSubs[sub];
      var u = (usedSubs && usedSubs[sub]) ? usedSubs[sub] : { val: 0, unit: t.unit };
      var avail = Math.max(t.val - u.val, 0);
      var label = (sub ? escHtml(sub) + ': ' : '') +
                  escHtml(formatGresVal(avail, t.unit)) + ' / ' +
                  escHtml(formatGresVal(t.val, t.unit));
      html += nodeResourceBar(avail, t.val, label);
    });
    return html || '<span class="text-muted small">—</span>';
  }

  // Scan all rows and return ordered list of unique top-level GRES type names.
  function discoverGresTypes(rows) {
    var seen = {};
    rows.forEach(function(row) {
      Object.keys(parseGresMap(row.gres || '')).forEach(function(t) { seen[t] = true; });
    });
    return Object.keys(seen).sort();
  }

  function parseCpus(cpusState) {
    var parts = (cpusState || '').split('/');
    if (parts.length !== 4) return null;
    return { idle: parseInt(parts[1], 10), total: parseInt(parts[3], 10) };
  }

  function nodeResourceBar(avail, total, label) {
    if (total <= 0) return '<span class="text-muted small">—</span>';
    var pct   = Math.min(Math.round((total - avail) / total * 100), 100);
    var color = pct < 50 ? 'bg-success' : pct < 80 ? 'bg-warning' : 'bg-danger';
    var lbl   = label !== undefined ? label : (avail + ' / ' + total);
    return '<div><div class="progress" style="height:5px;min-width:70px;"><div class="progress-bar ' + color + '" style="width:' + pct + '%;"></div></div><small class="text-nowrap">' + escHtml(lbl) + '</small></div>';
  }

  function activeStates() {
    var cbs = Array.from(document.querySelectorAll('.nodes-state-cb'));
    if (!cbs.length) return null;
    var checked = cbs.filter(function(cb) { return cb.checked; });
    if (checked.length === cbs.length) return null;
    return new Set(checked.map(function(cb) { return cb.value; }));
  }

  function rowVisible(row) {
    var state  = (row.dataset.state  || '').toLowerCase();
    var text   = (row.dataset.search || '').toLowerCase();
    var search = (searchEl ? searchEl.value : '').toLowerCase().trim();
    var states = activeStates();

    if (states && !states.has(state)) return false;
    if (search && !text.includes(search)) return false;
    return true;
  }

  function update() {
    var sorted = allRows.slice();
    if (sortCol !== null) {
      sorted.sort(function(a, b) {
        var av = (a.cells[sortCol] ? a.cells[sortCol].textContent : '').trim();
        var bv = (b.cells[sortCol] ? b.cells[sortCol].textContent : '').trim();
        var cmp = av.localeCompare(bv, undefined, { numeric: true, sensitivity: 'base' });
        return sortAsc ? cmp : -cmp;
      });
    }
    var visible = 0;
    sorted.forEach(function(row) {
      var show = rowVisible(row);
      row.style.display = show ? '' : 'none';
      if (show) visible++;
      tbody.appendChild(row);
    });
    if (countEl) countEl.textContent = visible;
    if (emptyEl) emptyEl.style.display = (visible === 0 && totalNodes > 0) ? '' : 'none';
  }

  function populateStateFilter(uniqueStates) {
    var list = document.getElementById('_nodesStatesList');
    if (!list) return;
    uniqueStates.forEach(function(st) {
      var div = document.createElement('div');
      div.className = 'form-check form-check-inline mb-0';
      div.innerHTML =
        '<input class="form-check-input nodes-state-cb" type="checkbox"' +
        ' id="nst-' + escHtml(st) + '" value="' + escHtml(st) + '" checked>' +
        '<label class="form-check-label" for="nst-' + escHtml(st) + '">' + nodeStateBadge(st) + '</label>';
      list.appendChild(div);
      div.querySelector('input').addEventListener('change', update);
    });
    if (uniqueStates.length > 0) document.getElementById('_nodesStatesSection').style.display = '';
  }

  function buildSummary(rows) {
    if (!summaryEl) return;
    var stateCounts = {};
    rows.forEach(function(r) {
      var st = (r.state || '').toLowerCase();
      stateCounts[st] = (stateCounts[st] || 0) + 1;
    });
    var summaryOrder = [
      ['idle',      'success'],
      ['allocated', 'primary'],
      ['mixed',     'warning text-dark'],
      ['down',      'danger'],
      ['drained',   'secondary'],
      ['draining',  'warning text-dark']
    ];
    var known = summaryOrder.map(function(x) { return x[0]; });
    var html = '<span class="badge bg-dark" style="font-size:.85rem;">' + rows.length + ' nodes total</span>';
    summaryOrder.forEach(function(pair) {
      var st = pair[0]; var css = pair[1];
      var count = stateCounts[st] || 0;
      if (count > 0) html += '<span class="badge bg-' + css + '">' + count + ' ' + escHtml(st) + '</span>';
    });
    Object.keys(stateCounts).forEach(function(st) {
      if (known.indexOf(st) >= 0) return;
      html += '<span class="badge bg-secondary">' + stateCounts[st] + ' ' + escHtml(st) + '</span>';
    });
    summaryEl.innerHTML = html;
  }

  function buildTable(rows) {
    // Discover GRES types from all rows and rebuild dynamic header columns.
    gresTypes = discoverGresTypes(rows);
    var thead = table.querySelector('thead tr');
    Array.from(thead.querySelectorAll('.gres-col-th')).forEach(function(th) { th.remove(); });
    gresTypes.forEach(function(type, i) {
      var th = document.createElement('th');
      th.className = 'user-select-none gres-col-th';
      th.style.whiteSpace = 'nowrap';
      th.dataset.col = 4 + i;
      th.innerHTML = escHtml(type.charAt(0).toUpperCase() + type.slice(1)) +
                     ' <span class="text-muted nodes-sort-neutral" style="font-size:.7em;">⇅</span>';
      setupSortTh(th);
      thead.appendChild(th);
    });

    tbody.innerHTML = '';
    allRows = [];
    rows.forEach(function(row) {
      var cpu       = parseCpus(row.cpus || '');
      var freememMb = parseInt((row.freemem || '').replace(/[^\d]/g, ''), 10) || 0;
      var memoryMb  = parseInt((row.memory  || '').replace(/[^\d]/g, ''), 10) || 0;
      var freeGb    = (freememMb / 1024).toFixed(1).replace(/\.0$/, '');
      var totalGb   = (memoryMb  / 1024).toFixed(1).replace(/\.0$/, '');
      var totalGres = parseGresMap(row.gres     || '');
      var usedGres  = parseGresMap(row.gresused || '');
      var gresSearch = Object.keys(totalGres).join(' ');
      var searchStr  = [row.node, row.state, row.cpus, freeGb + ' ' + totalGb, gresSearch].join(' ').toLowerCase();

      var tr = document.createElement('tr');
      tr.dataset.state  = (row.state || '').toLowerCase().trim();
      tr.dataset.node   = (row.node  || '').toLowerCase();
      tr.dataset.search = searchStr;

      var cpuHtml = cpu
        ? nodeResourceBar(cpu.idle, cpu.total, cpu.idle + ' / ' + cpu.total)
        : '<span class="text-muted small">—</span>';
      var memHtml = nodeResourceBar(freememMb, memoryMb, freeGb + ' / ' + totalGb + ' GB');

      tr.innerHTML =
        '<td><code>' + escHtml(row.node || '') + '</code></td>' +
        '<td>' + nodeStateBadge(row.state || '') + '</td>' +
        '<td>' + cpuHtml + '</td>' +
        '<td>' + memHtml + '</td>';

      gresTypes.forEach(function(type) {
        var td = document.createElement('td');
        td.innerHTML = gresCellHtml(totalGres[type] || {}, usedGres[type]);
        tr.appendChild(td);
      });

      tbody.appendChild(tr);
      allRows.push(tr);
    });
  }

  function showError(msg) {
    loadingEl.style.display = 'none';
    errorEl.textContent     = msg;
    errorEl.style.display   = '';
  }

  function showContent(fetchedAt, rowCount) {
    loadingEl.style.display = 'none';
    contentEl.style.display = '';
    if (fetchedEl) fetchedEl.textContent = 'Fetched at ' + fetchedAt;
    totalNodes = rowCount;
    if (totalEl) totalEl.textContent = rowCount;
  }

  function loadData() {
    var url = DATA_URL + (CLUSTER ? '?cluster=' + encodeURIComponent(CLUSTER) : '');
    fetch(url)
      .then(function(r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      })
      .then(function(data) {
        if (data.error) { showError(data.error); return; }
        var rows = data.rows || [];

        var uniqueStates = [], statesSeen = {};
        rows.forEach(function(r) {
          var st = (r.state || '').toLowerCase();
          if (st && !statesSeen[st]) { uniqueStates.push(st); statesSeen[st] = true; }
        });
        uniqueStates.sort();

        populateStateFilter(uniqueStates);
        buildSummary(rows);
        buildTable(rows);
        showContent(data.fetched_at, rows.length);
        update();
      })
      .catch(function(err) { showError('Failed to fetch node data: ' + err); });
  }

  var table = document.getElementById('_nodesTable');

  function setupSortTh(th) {
    th.style.cursor = 'pointer';
    th.title = 'Click to sort';
    th.addEventListener('click', function() {
      var col = parseInt(this.dataset.col);
      table.querySelectorAll('thead .sort-ind').forEach(function(el) { el.remove(); });
      table.querySelectorAll('thead .nodes-sort-neutral').forEach(function(el) { el.style.display = ''; });
      if (sortCol === col) {
        sortAsc = !sortAsc;
      } else {
        sortCol = col;
        sortAsc = true;
      }
      var neutral = this.querySelector('.nodes-sort-neutral');
      if (neutral) neutral.style.display = 'none';
      var ind = document.createElement('span');
      ind.className    = 'sort-ind text-primary';
      ind.style.fontSize = '0.7em';
      ind.textContent  = ' ' + (sortAsc ? '▲' : '▼');
      this.appendChild(ind);
      update();
    });
  }

  table.querySelectorAll('thead th[data-col]').forEach(setupSortTh);

  if (searchEl) searchEl.addEventListener('input', update);
  document.querySelectorAll('.nodes-cluster-radio').forEach(function(radio) {
    radio.addEventListener('change', function() {
      var url = new URL(window.location.href);
      url.searchParams.set('cluster', radio.value);
      window.location.href = url.toString();
    });
  });

  var refreshTimer = null;
  document.getElementById('_nodesAutoRefresh').addEventListener('change', function() {
    if (this.checked) {
      refreshTimer = setInterval(function() { window.location.reload(); }, 30000);
    } else {
      clearInterval(refreshTimer);
      refreshTimer = null;
    }
  });

  loadData();
})();
</script>
